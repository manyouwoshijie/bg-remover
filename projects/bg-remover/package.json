{
  "name": "bg-remover",
  "version": "1.0.0",
  "description": "Image background remover powered by Remove.bg API, deployed on Cloudflare Pages",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name bg-remover",
    "db:migrate": "wrangler d1 execute bg-remover-db --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "@auth/d1-adapter": "^1.7.4",
    "@cloudflare/next-on-pages": "^1.11.3",
    "next": "15.2.0",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3.111.0"
  }
}
